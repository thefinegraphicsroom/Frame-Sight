{
  "name": "framesight",
  "version": "1.0.0",
  "description": "Real-time OCR Overlay Tool for Honor of Kings / MLBB Broadcasts",
  "main": "main.js",
  "scripts": {
    "start": "electron . 2>nul",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.framesight",
    "productName": "FrameSight",
    "directories": { "output": "dist" },
    "win": { "target": "nsis" },
    "mac": { "target": "dmg" },
    "linux": { "target": "AppImage" }
  }
}